# ─────────────────────────────────────────────────────────────────────────
# Etereo Backend — Variables de entorno requeridas
# Copiar este archivo como .env.local y completar los valores reales.
# NUNCA commitear .env.local ni .env con valores reales.
# ─────────────────────────────────────────────────────────────────────────

# PostgreSQL — connection string en formato Npgsql / Railway
# Formato: Host=host;Port=5432;Database=railway;Username=postgres;Password=xxx
# Railway provee DATABASE_URL en formato postgresql://user:pass@host:port/db
DATABASE_URL=Host=localhost;Port=5432;Database=etereo;Username=postgres;Password=postgres

# JWT — HS256
# Secret de al menos 32 caracteres (recomendado: 64+ aleatorios)
JWT_SECRET_KEY=cambia-esto-por-una-clave-secreta-de-al-menos-32-caracteres
JWT_ISSUER=etereo-api
JWT_AUDIENCE=etereo-app

# Resend — envío de emails transaccionales
# Obtener en https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# El remitente debe estar verificado en Resend
RESEND_FROM_EMAIL=Etereo <noreply@etereo.com>

# Google OAuth
# Obtener en https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=xxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com

# Contraseña del usuario admin creado por el seeder
ADMIN_PASSWORD=Admin1234!

# CORS — origins permitidos en producción (separados por coma, sin espacios)
# En desarrollo se permite localhost:5173 automáticamente
CORS_ALLOWED_ORIGINS=https://etereo.com,https://www.etereo.com
